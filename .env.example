# OpenRouteService API key — get yours free at:
# https://openrouteservice.org/dev/#/signup
# (2000 requests/day on the free tier)
ORS_API_KEY=your_key_here

# Shared PostgreSQL runtime
POSTGRES_DB=bossuyt
POSTGRES_USER=bossuyt
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432
DATABASE_URL=postgres://bossuyt:change_me@localhost:5432/bossuyt
DATABASE_URL_DOCKER=postgres://bossuyt:change_me@db:5432/bossuyt
DATABASE_URL_STAGING_DOCKER=postgres://bossuyt:change_me@db-staging:5432/bossuyt_staging
